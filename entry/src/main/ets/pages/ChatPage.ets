  async aboutToAppear() {
    const params = router.getParams() as Record<string, string>;
    if (params && params.userId && params.userName) {
      this.userId = params.userId;
      this.userName = params.userName;
      this.userAvatar = params.userAvatar || '';
      this.currentUserId = await StorageService.getItemAsync<string>('userId') || '';

      await this.loadMessages();
      await this.loadUserStatus(); // рҹ”§ зңҹе®һпјҡиҝӣе…ҘйЎөйқўз«ӢеҚіжҹҘдёҖж¬ЎеңЁзәҝзҠ¶жҖҒ

      // рҹ”§ зңҹе®һпјҡејҖеҗҜе®ҡж—¶еҷЁпјҢжҜҸ30з§’еҲ·ж–°дёҖж¬ЎеңЁзәҝзҠ¶жҖҒ
      this.statusUpdateInterval = setInterval(async () => {
        await this.loadUserStatus();
      }, 30000);
    } else {
      promptAction.showToast({ message: 'еҸӮж•°й”ҷиҜҜ', duration: 2000 });
      router.back();
    }
  }

  aboutToDisappear() {
    if (this.statusUpdateInterval !== -1) {
      clearInterval(this.statusUpdateInterval);
    }
  }

  // рҹ”§ зңҹе®һе®һзҺ°пјҡйҖҡиҝҮжҺҘеҸЈиҺ·еҸ–еҜ№ж–№еңЁзәҝзҠ¶жҖҒ
  async loadUserStatus(): Promise<void> {
    try {
      const response: ApiResponse<UserStatusData> = await this.userService.getUserStatus(this.userId);
      if (response.code === 200 && response.data) {
        if (response.data.isOnline !== undefined) {
          this.isOnline = response.data.isOnline;
        }
        if (response.data.lastSeen !== undefined) {
          this.lastSeen = response.data.lastSeen;
        }
      }
    } catch (error) {
      console.error('иҺ·еҸ–зҠ¶жҖҒеӨұиҙҘ:', error);
    }
  }

  async loadMessages(): Promise<void> {
    this.isLoading = true;
    try {
      // е…Ҳж Үи®°ж¶ҲжҒҜдёәе·ІиҜ»
      await this.userService.markChatMessageAsRead(this.userId);

      // з„¶еҗҺеҠ иҪҪж¶ҲжҒҜеҲ—иЎЁ
      const response: ApiResponse<Message[]> = await this.userService.getMessages(this.userId);
      if (response.code === 200 && response.data) {
        const rawList: Message[] = response.data;
        const newList: Message[] = [];

        for (let i = 0; i < rawList.length; i++) {
          const msg: Message = rawList[i];
          let newMsg: Message = {
            id: msg.id,
            content: msg.content,
            senderId: msg.senderId,
            recipientId: msg.recipientId,
            createdAt: msg.createdAt,
            isSent: msg.senderId === this.currentUserId,
            status: msg.senderId === this.currentUserId ? (msg.isRead ? 'read' : 'sent') : undefined,
            isRead: msg.isRead || false
          };
          newList.push(newMsg);
        }
        this.messages = newList;

        setTimeout(() => {
          this.scrollToBottom(false);
        }, 100);
      }
    } catch (error) {
      console.error('еҠ иҪҪеӨұиҙҘ:', error);
      promptAction.showToast({ message: 'еҠ иҪҪж¶ҲжҒҜеӨұиҙҘ' });
    } finally {
      this.isLoading = false;
    }
  }

  scrollToBottom(animate: boolean = true): void {
    if (this.messages.length > 0) {
      this.listScroller.scrollToIndex(this.messages.length - 1, animate);
    }
  }

  async sendMessage(): Promise<void> {
    const content: string = this.inputText.trim();
    if (!content) return;

    const tempId: string = 'temp_' + Date.now();
    // еҲқе§ӢзҠ¶жҖҒи®ҫдёә sent
    const tempMsg: Message = {
      id: tempId,
      content: content,
      senderId: this.currentUserId,
      recipientId: this.userId,
      createdAt: new Date().toISOString(),
      isSent: true,
      status: 'sent',
      isRead: false
    };

    let newMsgs: Message[] = this.messages.concat([tempMsg]);
    this.messages = newMsgs;
    this.inputText = '';
    this.showEmojiPanel = false;
    setTimeout(() => this.scrollToBottom(), 50);

    try {
      const response: ApiResponse<SendResultData> = await this.userService.sendMessage(this.userId, content);
      if (response.code === 200) {
        // рҹ”§ зңҹе®һйҖ»иҫ‘ 1пјҡжҺҘеҸЈиҝ”еӣһжҲҗеҠҹпјҢд»ЈиЎЁгҖҗе·ІеҸ‘йҖҒгҖ‘
        this.updateMsgStatus(tempId, 'sent');

        // рҹ”§ зңҹе®һйҖ»иҫ‘ 2пјҡеҰӮжһңеҪ“еүҚеҜ№ж–№жӯЈеҘҪеңЁзәҝпјҢжҲ‘д»¬и®Өдёәж¶ҲжҒҜгҖҗе·ІиҜ»гҖ‘
        // (иҝҷжҳҜеңЁжІЎжңүй•ҝиҝһжҺҘжҺЁйҖҒдёӢзҡ„еҗҲзҗҶз®ҖеҢ–пјҢзңҹе®һIMйңҖиҰҒWebSocket)
        if (this.isOnline) {
          // зЁҚеҫ®е»¶иҝҹдёҖзӮ№зӮ№пјҢжЁЎжӢҹзҪ‘з»ңдј иҫ“е’ҢжҹҘзңӢж—¶й—ҙ
          setTimeout(() => {
            this.updateMsgStatus(tempId, 'read');
          }, 1000);
        }
      } else {
        throw new Error('еҸ‘йҖҒеӨұиҙҘ');
      }
    } catch (error) {
      console.error('еҸ‘йҖҒеӨұиҙҘ:', error);
      promptAction.showToast({ message: 'зҪ‘з»ңејӮеёё' });
    }
  }

  // з®ҖеҢ–еҸӮж•°зұ»еһӢ
  updateMsgStatus(id: string, status: 'sent' | 'read'): void {
    const idx: number = this.findMsgIndexById(id);
    if (idx !== -1) {
      let newMsgs: Message[] = this.messages.slice();
      newMsgs[idx].status = status;
      if (status === 'read') {
        newMsgs[idx].isRead = true;
      }
      this.messages = newMsgs;
    }
  }

  findMsgIndexById(id: string): number {
    for (let i = 0; i < this.messages.length; i++) {
      if (this.messages[i].id === id) {
        return i;
      }
    }
    return -1;
  }

  formatTime(timestamp: string): string {
    if (!timestamp) return '';
    const date: Date = new Date(timestamp);
    const h: string = (date.getHours() < 10 ? '0' : '') + date.getHours();
    const m: string = (date.getMinutes() < 10 ? '0' : '') + date.getMinutes();
    return h + ':' + m;
  }

  // еҸӘиҝ”еӣһдёӨз§Қж–Үеӯ—
  getStatusDisplay(status?: 'sent' | 'read'): string {
    if (status === 'read') return 'е·ІиҜ»';
    return 'е·ІеҸ‘йҖҒ'; // е·ІеҸ‘йҖҒзҠ¶жҖҒдёҚжҳҫзӨәж–Үеӯ—пјҢжҲ–иҖ…жҳҫзӨә 'е·ІеҸ‘йҖҒ'
  }

  getStatusColor(status?: 'sent' | 'read'): ResourceColor {
    if (status === 'read') return '#4CAF50';
    return '#999999';
  }

  build() {
    Column() {
      this.buildHeader();
      if (this.isLoading) {
        this.buildLoading();
      } else {
        this.buildMsgList();
      }

      // рҹ”§ е…ій”®дҝ®ж”№пјҡеә•йғЁеҢәеҹҹз»ҹдёҖз®ЎзҗҶ
      Column() {
        // еҰӮжһңжҳҫзӨәиЎЁжғ…пјҢе…ҲжёІжҹ“иЎЁжғ…йқўжқҝ
        if (this.showEmojiPanel) {
          this.buildEmojiPanel();
        }
        // еҶҚжёІжҹ“иҫ“е…ҘжЎҶ
        this.buildInputBar();
      }
      .width('100%')
    }
    .width('100%')
    .height('100%')
    .backgroundColor('#F5F5F5');
  }

  @Builder
  buildHeader() {
    Row() {
      Button('иҝ”еӣһ')
        .backgroundColor(Color.Transparent)
        .fontColor('#D32F2F')
        .onClick(() => router.back());

      Column() {
        Text(this.userName).fontSize(18).fontWeight(FontWeight.Bold);
        // рҹ”§ иҝҷйҮҢжҳҫзӨәзҡ„еңЁзәҝ/зҰ»зәҝжҳҜзңҹе®һзҡ„пјҢжқҘиҮӘ loadUserStatus жҺҘеҸЈ
        Text(this.isOnline ? 'еңЁзәҝ' : 'зҰ»зәҝ')
          .fontSize(12)
          .fontColor(this.isOnline ? '#4CAF50' : '#999999');
      }
      .layoutWeight(1)
      .alignItems(HorizontalAlign.Center);

      Button('жӣҙеӨҡ')
        .backgroundColor(Color.Transparent)
        .fontColor('#666666')
        .onClick(() => promptAction.showToast({ message: 'ејҖеҸ‘дёӯ' }));
    }
    .width('100%')
    .height(56)
    .padding({ left: 8, right: 8 })
    .backgroundColor('#FFFFFF')
    .shadow({ radius: 2, color: '#00000010', offsetY: 2 });
  }

  @Builder
  buildLoading() {
    Column() {
      LoadingProgress().width(40).height(40);
    }
    .width('100%')
    .layoutWeight(1)
    .justifyContent(FlexAlign.Center);
  }

  @Builder
  buildMsgList() {
    List({ scroller: this.listScroller }) {
      ForEach(this.messages, (msg: Message) => {
        ListItem() {
          if (msg.isSent) {
            this.buildRightBubble(msg);
          } else {
            this.buildLeftBubble(msg);
          }
        }
      }, (msg: Message) => msg.id);
    }
    .width('100%')
    .layoutWeight(1) // еҚ жҚ®еү©дҪҷз©әй—ҙ
    .padding({ top: 8, bottom: 8 }) // рҹ”§ иҝҷйҮҢзҡ„ bottom еҸҜд»Ҙдҝқз•ҷпјҢи®©жңҖеҗҺдёҖжқЎж¶ҲжҒҜдёҚиҙҙиҫ№
    .backgroundColor('#F5F5F5')
    .alignListItem(ListItemAlign.Start); // зЎ®дҝқеҲ—иЎЁйЎ№еҜ№йҪҗ
  }

  @Builder
  buildLeftBubble(msg: Message) {
    Row() {
      if (this.userAvatar) {
        Image(this.userAvatar)
          .width(40)
          .height(40)
          .borderRadius(20)
          .margin({ right: 12, left: 16 })
          .objectFit(ImageFit.Cover);
      } else {
        Text(this.userName.charAt(0))
          .width(40)
          .height(40)
          .borderRadius(20)
          .backgroundColor('#D32F2F')
          .fontColor('#FFFFFF')
          .textAlign(TextAlign.Center)
          .margin({ right: 12, left: 16 });
      }

      Column() {
        Text(msg.content)
          .fontSize(16)
          .padding(12)
          .backgroundColor('#FFFFFF')
          .borderRadius({
            topLeft: 0,
            topRight: 16,
            bottomLeft: 16,
            bottomRight: 16
          })
          .constraintSize({ maxWidth: '70%' });

        Text(this.formatTime(msg.createdAt))
          .fontSize(10).fontColor('#999999')
          .margin({ top: 4 });
      }
      .alignItems(HorizontalAlign.Start);

      Blank();
    }
    .width('100%')
    .padding({ top: 4, bottom: 4 });
  }

  @Builder
  buildRightBubble(msg: Message) {
    Row() {
      Blank();

      Column() {
        Row() {
          Column() {
            // рҹ”§ еҸӘжңүе·ІиҜ»ж—¶жүҚжҳҫзӨәж–Үеӯ—
            Text(this.getStatusDisplay(msg.status))
              .fontSize(12)
              .fontColor(this.getStatusColor(msg.status))
              .margin({ right: 4 });
            Text(this.formatTime(msg.createdAt))
              .fontSize(10).fontColor('#999999');
          }
          .alignItems(HorizontalAlign.End)
          .margin({ right: 6 });

          Text(msg.content)
            .fontSize(16)
            .padding(12)
            .backgroundColor('#D32F2F')
            .fontColor('#FFFFFF')
            .borderRadius({
              topLeft: 16,
              topRight: 0,
              bottomLeft: 16,
              bottomRight: 16
            })
            .constraintSize({ maxWidth: '70%' });
        }
        .alignItems(VerticalAlign.Bottom);
      }
      .alignItems(HorizontalAlign.End);

      Text('жҲ‘')
        .width(40)
        .height(40)
        .borderRadius(20)
        .backgroundColor('#999999')
        .fontColor('#FFFFFF')
        .textAlign(TextAlign.Center)
        .margin({ left: 12, right: 16 });
    }
    .width('100%')
    .padding({ top: 4, bottom: 4 });
  }

  @Builder
  buildEmojiPanel() {
    Column() {
      // рҹ”§ дҝ®еӨҚпјҡеҺ»жҺүдёҚеӯҳеңЁзҡ„ scrollEdge еұһжҖ§
      Scroll() {
        Flex({ wrap: FlexWrap.Wrap, justifyContent: FlexAlign.SpaceAround }) {
          ForEach(this.emojis, (emoji: string) => {
            Text(emoji)
              .fontSize(28)
              .width('12.5%')
              .height(44)
              .textAlign(TextAlign.Center)
              .onClick(() => {
                this.inputText = this.inputText + emoji;
              });
          });
        }
        .width('100%')
        .padding({ left: 12, right: 12, top: 8, bottom: 8 })
      }
      .width('100%')
      .height(260)
      .scrollBar(BarState.Auto) // дҝқз•ҷиҝҷдёӘпјҢжҳҫзӨәж»ҡеҠЁжқЎ
      .backgroundColor('#FFFFFF');

      Divider()
        .color('#E0E0E0')
        .strokeWidth(0.5)
    }
    .width('100%');
  }

  @Builder
  buildInputBar() {
    Row() {
      Button('рҹҳҖ')
        .fontSize(20)
        .backgroundColor(Color.Transparent)
        .width(60)
        .height(60)
        .onClick(() => {
          this.showEmojiPanel = !this.showEmojiPanel;
        });

      TextInput({ placeholder: 'иҫ“е…Ҙж¶ҲжҒҜ...', text: this.inputText })
        .layoutWeight(1)
        .height(40)
        .backgroundColor('#F0F0F0')
        .borderRadius(20)
        .padding({ left: 16, right: 16 })
        .onChange((val: string) => {
          this.inputText = val;
        })
        .onFocus(() => {
          // иҒҡз„Ұиҫ“е…ҘжЎҶж—¶е…ій—ӯиЎЁжғ…
          this.showEmojiPanel = false;
        });

      Button('еҸ‘йҖҒ')
        .width(64)
        .height(40)
        .margin({ left: 12 })
        .backgroundColor(this.inputText.trim() ? '#D32F2F' : '#CCCCCC')
        .fontColor('#FFFFFF')
        .borderRadius(20)
        .enabled(this.inputText.trim().length > 0)
        .onClick(() => {
          this.sendMessage();
        });
    }
    .width('100%')
    .padding({
      left: 12,
      right: 12,
      top: 8,
      bottom: 8
    })
    .backgroundColor('#FFFFFF');
  }
}